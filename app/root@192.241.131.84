def plot_rf_metrics(metrics_file='RF_metrics.csv'):
 
    # Load the metrics file
    df = pd.read_csv(metrics_file)
    
    if df.empty:
        print("The metrics file is empty. No data to plot.")
        return
    
    # Set the model names as index
    df.set_index('Model', inplace=True)
    
    # Define metrics to plot
    metrics = ['accuracy', 'precision', 'recall', 'f1', 'roc_auc']
    
    # Create a bar plot
    ax = df[metrics].plot(kind='bar', figsize=(12, 6), colormap='viridis', edgecolor='black')
    
    plt.title("Performance Metrics of Random Forest Models", fontsize=14)
    plt.xlabel("Model", fontsize=12)
    plt.ylabel("Score", fontsize=12)
    plt.xticks(rotation=45, ha='right')
    plt.grid(axis='y', linestyle='--', alpha=0.7)
    
    # Move the legend outside the plot
    plt.legend(title="Metrics", bbox_to_anchor=(1.05, 1), loc='upper left')

    # Display values above the bars
    for p in ax.patches:
        height = p.get_height()
        if not pd.isna(height):
            ax.annotate(f"{height:.2f}",
                        (p.get_x() + p.get_width() / 2., height),
                        ha='center', va='bottom', fontsize=10, color='black', fontweight='bold', rotation=90)
    
    # Adjust layout to prevent clipping
    plt.tight_layout()
    RF_metrics_plot = os.path.join(TMP_FILES_DIR, 'RF_metrics_plot.png')
    # Save the plot as an image
    plt.savefig(RF_metrics_plot, dpi=300, bbox_inches='tight')
    plt.show()
    

def filter_selected_aids(matrix_file='bioprofile_matrix.csv', output_file='Selected_bioprofile_matrix.csv'):
    """
    Filters the bioprofile matrix to include only AIDs for which we have RF models.
    
    Parameters:
    matrix_file (str): Path to the bioprofile matrix file.
    output_file (str): Path to save the filtered bioprofile matrix.
    
    Returns:
    selected_df (DataFrame): The filtered matrix.
    """
    # matrix_file = os.path.join(TMP_FILES_DIR, 'bioprofile_matrix.csv')

    try:
        # Load the bioprofile matrix
        df = pd.read_csv(matrix_file, index_col=0)
        print(f"Loaded matrix with shape: {df.shape}")

        # Get available RF models
        model_files = glob.glob(os.path.join(TMP_FILES_DIR, "AID*_diverse.pkl"))
        model_aids = [os.path.basename(f).split('_')[0][3:] for f in model_files]  # Extract AID numbers
        
        if not model_aids:
            raise ValueError("No RF models found. Ensure RF models are saved as 'AID{aid}_diverse.pkl'.")

        # Filter matrix to include only relevant AIDs
        selected_cols = [aid for aid in model_aids if aid in df.columns]
        
        if not selected_cols:
            raise ValueError("No matching AIDs found between bioprofile matrix and available RF models.")
        
        selected_df = df[selected_cols]
        # output_file = os.path.join(TMP_FILES_DIR, 'Selected_bioprofile_matrix.csv')

        selected_df.to_csv(output_file)
        
        print(f"Filtered matrix saved as {output_file} with shape: {selected_df.shape}")
        return selected_df

    except Exception as e:
        print(f"Error in filtering selected AIDs: {e}")
        return None

def generate_ecfp6_fingerprint(inchi):
    """
    Generates an ECFP6 fingerprint for a given InChI.
    
    Parameters:
    inchi (str): InChI string of the molecule.
    
    Returns:
    np.array: ECFP6 fingerprint array.
    """
    mol = Chem.MolFromInchi(inchi)
    if mol:
        fp = AllChem.GetMorganFingerprintAsBitVect(mol, 3, nBits=2048)
        arr = np.zeros((1,))
        DataStructs.ConvertToNumpyArray(fp, arr)
        return arr
    else:
        return np.zeros((2048,))  # Return zero vector if molecule is invalid

def fetch_inchi_for_cids(cids):
    """
    Fetches InChI values for a list of CIDs from PubChem.
    
    Parameters:
    cids (list): List of CIDs to fetch InChIs.
    
    Returns:
    dict: Dictionary mapping CID to InChI.
    """
    url = "https://pubchem.ncbi.nlm.nih.gov/rest/pug/compound/cid/property/InChI/CSV"
    headers = {'Content-Type': 'application/x-www-form-urlencoded'}
    inchi_dict = {}

    for i in range(0, len(cids), 20):  # PubChem allows up to 20 CIDs per request
        batch = cids[i:i+20]
         
        data = {'cid': ','.join(map(str, batch))}
        
        try:
            response = requests.post(url, data=data, headers=headers, timeout=10)
            response.raise_for_status()
            df = pd.read_csv(StringIO(response.text))
            
            for _, row in df.iterrows():
                inchi_dict[row['CID']] = row['InChI']
                
        except Exception as e:
            print(f"Error fetching InChI for batch {batch}: {e}")
            continue

    return inchi_dict

def replace_negative_one_with_predictions(matrix_file='Selected_bioprofile_matrix.csv', output_file='DataFilled_bioprofile_matrix.csv'):
    """
    Replaces -1 values in bioprofile matrix with RF model predictions.
    """
    try:
        df = pd.read_csv(matrix_file, index_col=0)
        print(f"Loaded selected matrix with shape: {df.shape}")

        model_files = glob.glob(os.path.join(TMP_FILES_DIR, "AID*_diverse.pkl"))
        model_aids = [os.path.basename(f).split('_')[0][3:] for f in model_files]

        print(f"🔍 Searching for models in: {TMP_FILES_DIR}")

        # Log file to record replaced values
        log_data = []

        for aid in model_aids:
            if aid not in df.columns:
                continue  # Skip if AID is not present in the matrix

            model_file = os.path.join(TMP_FILES_DIR, f"AID{aid}_diverse.pkl")
            print(f"🔍 Looking for model file: {model_file}")

            if not os.path.exists(model_file):
                print(f"⚠️ Model file missing: {model_file}. Skipping AID {aid}.")
                continue

            # Load the RF model
            try:
                model = joblib.load(model_file)
                print(f"Loaded model: {model_file}")
            except Exception as e:
                print(f"Error loading model {model_file}: {e}")
                continue

            # Find CIDs with -1 values
            cids_to_predict = df[df[aid] == -1].index.tolist()
            if not cids_to_predict:
                print(f"ℹ️ No -1 values found for AID {aid}, skipping.")
                continue

            # Fetch InChI for CIDs
            inchi_dict = fetch_inchi_for_cids(cids_to_predict)

            # Generate fingerprints for valid CIDs
            fingerprints = []
            valid_cids = []

            for cid in cids_to_predict:
                inchi = inchi_dict.get(cid)
                if inchi:
                    fp = generate_ecfp6_fingerprint(inchi)
                    fingerprints.append(fp)
                    valid_cids.append(cid)

            if not fingerprints:
                print(f"⚠️ No valid fingerprints found for AID {aid}, skipping.")
                continue

            # Convert fingerprints to numpy array and predict values
            fingerprints = np.array(fingerprints)
            predictions = model.predict(fingerprints).astype(int)

            # Replace -1 with predictions
            for cid, pred in zip(valid_cids, predictions):
                df.at[cid, aid] = pred
                log_data.append([cid, aid, pred])

            print(f"Replaced {len(valid_cids)} values for AID {aid}.")
            
        output_file = os.path.join(TMP_FILES_DIR, 'DataFilled_bioprofile_matrix.csv')
        df = df.sort_index(axis=0, ascending=True)  # Sort rows in ascending order
        df = df.sort_index(axis=1, ascending=True)  # Sort columns in ascending ord
        df.to_csv(output_file)
        print(f"Updated matrix saved as {output_file}")

        # Save log file
        log_file = os.path.join(TMP_FILES_DIR, 'replaced_values_log.csv')
        pd.DataFrame(log_data, columns=['CID', 'AID', 'Predicted_Value']).to_csv(log_file, index=False)
        print(f"Log of replaced values saved as {log_file}")

        return df

    except Exception as e:
        print(f"Error in replacing -1 values with predictions: {e}")
        return None

